# =============================================================================
# ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env (development) or set these in your hosting provider.
# Never commit .env files to version control!
#
# Required variables are marked with [REQUIRED].
# Optional variables are marked with [OPTIONAL].
# =============================================================================


# =============================================================================
# DATABASE [REQUIRED]
# =============================================================================
# PostgreSQL connection string.
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
#
# Local development:
#   1. Install PostgreSQL: https://www.postgresql.org/download/
#      Or run via Docker: docker run -e POSTGRES_PASSWORD=password -p 5432:5432 postgres
#   2. Create a database: createdb nextjs_saas_starter
#
# Production options:
#   - Supabase (free tier): https://supabase.com
#   - Neon (serverless, free tier): https://neon.tech
#   - Railway: https://railway.app
#   - Vercel Postgres: https://vercel.com/docs/storage/vercel-postgres
DATABASE_URL=postgresql://postgres:password@localhost:5432/nextjs_saas_starter


# =============================================================================
# REDIS [REQUIRED]
# =============================================================================
# Redis is mandatory — used for sessions, rate limiting, and user cache.
# The app will fail closed (503) on security operations if Redis is unavailable.
#
# Local development:
#   1. Install Redis: https://redis.io/download/
#      Or run via Docker: docker run -p 6379:6379 redis
#
# Production options:
#   - Redis Cloud: https://redis.com/cloud/
#   - AWS ElastiCache: https://aws.amazon.com/elasticache/
#   - Upstash (serverless, free tier): https://upstash.com
#
# Connection parameters for Redis Cloud, ElastiCache, or other managed Redis:
REDIS_HOST=redis-xxxxx.xxx.region.ec2.cloud.redislabs.com
REDIS_PORT=17826
REDIS_PASSWORD=your_redis_password
# REDIS_USER=default  # Optional: Some Redis providers require a username


# =============================================================================
# APPLICATION [REQUIRED]
# =============================================================================
# Public base URL of your application.
# Used for generating links in emails, OAuth redirect URIs, etc.
#
# Development: http://localhost:3000
# Production:  https://yourdomain.com  (no trailing slash)
BASE_URL=http://localhost:3000


# =============================================================================
# SECURITY [REQUIRED]
# =============================================================================
# Secret key for HMAC-SHA256 OTP hashing.
# Must be at least 32 characters long.
#
# Generate a secure secret (pick one):
#   macOS/Linux:  openssl rand -hex 32
#   Node.js:      node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   Online:       https://generate-secret.vercel.app/32
#
# WARNING: Never use the placeholder value in production.
#          Changing this secret invalidates all existing OTPs.
OTP_HMAC_SECRET=your-super-secret-hmac-key-minimum-32-characters-long


# =============================================================================
# EMAIL — Resend [REQUIRED for email delivery]
# =============================================================================
# Resend is the primary email provider for OTPs, invitations, and notifications.
#
# Setup:
#   1. Sign up at https://resend.com (free tier: 3,000 emails/month)
#   2. Go to Settings → API Keys → Create API Key
#   3. Copy the key (starts with "re_")
#
# Docs: https://resend.com/docs/introduction
#
# Note: If RESEND_API_KEY is not set, email sending is silently skipped.
#       This is useful for local development if you don't need to test emails.
RESEND_API_KEY=re_your_resend_api_key_here

# Sender email address — must be a verified domain in Resend.
#
# Setup:
#   1. In the Resend dashboard go to Domains → Add Domain
#   2. Add the required DNS records at your domain registrar
#   3. Once verified, use any address on that domain (e.g. noreply@yourdomain.com)
#
# For local development you can use any address — emails are only sent if
# RESEND_API_KEY is configured.
FROM_EMAIL=noreply@yourdomain.com


# =============================================================================
# CRON JOBS [REQUIRED]
# =============================================================================
# Secret token to authenticate requests to /api/cron/* endpoints.
# Must be at least 16 characters long.
#
# Generate a secure secret:
#   macOS/Linux:  openssl rand -hex 16
#   Node.js:      node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
#
# Include this as a Bearer token when calling cron endpoints:
#   Authorization: Bearer <CRON_SECRET>
#
# On Vercel, set this in vercel.json cron job headers or via the dashboard.
#
# WARNING: Never use the placeholder value in production.
CRON_SECRET=your-cron-secret-minimum-16-characters


# =============================================================================
# SUPER ADMIN BOOTSTRAP [REQUIRED — first deployment only]
# =============================================================================
# Credentials for the initial SUPER_ADMIN account created by the seed script.
# Run once after the first deployment: pnpm db:seed
#
# After seeding, this SUPER_ADMIN can invite additional admins via the UI.
# These variables are only read by prisma/seed.ts and are safe to remove
# after the initial seed.
#
# Password requirements: min 8 chars, strength score ≥ 3 (zxcvbn).
SUPER_ADMIN_EMAIL=admin@yourdomain.com
SUPER_ADMIN_PASSWORD=your-secure-super-admin-password


# =============================================================================
# CAPTCHA — Cloudflare Turnstile [OPTIONAL]
# =============================================================================
# Adds bot protection to login, registration, and password reset flows.
# If not configured, CAPTCHA is skipped entirely (both client and server).
#
# Setup:
#   1. Sign up at https://www.cloudflare.com (free)
#   2. Go to Turnstile in the dashboard sidebar
#   3. Click "Add site"
#   4. Enter your domain (use "localhost" for local testing)
#   5. Choose widget type — "Managed" is recommended
#   6. Copy the Site Key (public) and Secret Key (private)
#
# Docs: https://developers.cloudflare.com/turnstile/get-started/
#
# Note: Both keys must be set together, or neither should be set.
TURNSTILE_SECRET_KEY=your_turnstile_secret_key
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key


# =============================================================================
# FILE STORAGE — Google Drive [OPTIONAL]
# =============================================================================
# Store user avatars in Google Drive. If not configured, avatar upload
# functionality will be disabled and return a 500 error.
#
# Setup:
#   1. Go to https://console.cloud.google.com
#   2. Create a new project or select an existing one
#   3. Enable the Google Drive API:
#      - APIs & Services → Library → Search "Google Drive API" → Enable
#   4. Create a service account:
#      - APIs & Services → Credentials → Create Credentials → Service Account
#      - Service account name: e.g., "avatar-uploader"
#      - Click "Create and Continue"
#   5. Generate and download the service account key:
#      - Click on the service account you just created
#      - Go to "Keys" tab → "Add Key" → "Create New Key"
#      - Key type: JSON
#      - Download the JSON file and keep it secure
#   6. Extract values from the JSON file:
#      - client_email → GOOGLE_CLIENT_EMAIL
#      - private_key   → GOOGLE_PRIVATE_KEY (include all line breaks)
#      - The private_key is a multi-line value — preserve the \n characters
#   7. Create a Google Drive folder for avatars:
#      - Open https://drive.google.com
#      - Create a new folder (e.g., "User Avatars")
#      - Share the folder with the service account email:
#        - Right-click folder → Share → Add people
#        - Paste the service account email (client_email)
#        - Set role to "Contributor" or "Editor"
#      - Copy the folder ID from the URL:
#        https://drive.google.com/drive/folders/FOLDER_ID_HERE
#        FOLDER_ID_HERE → GOOGLE_DRIVE_FOLDER_ID
#
# Docs: https://developers.google.com/drive/api/guides/service-assets
#
# Note: All three variables must be set, or avatar upload will be disabled.
#       Private key must include literal "\n" characters for line breaks —
#       do NOT replace \n with actual newlines in the .env file.
#       The code will handle converting \n to actual newlines.
GOOGLE_CLIENT_EMAIL=avatar-uploader@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here...\n-----END PRIVATE KEY-----\n"
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id


# =============================================================================
# OAUTH PROVIDERS [OPTIONAL]
# =============================================================================
# Enable social login with Google and/or GitHub.
# Leave a provider's variables empty to disable it.
# Both providers can be enabled simultaneously.

# -----------------------------------------------------------------------------
# Google OAuth 2.0
# -----------------------------------------------------------------------------
# Setup:
#   1. Go to https://console.cloud.google.com
#   2. Create a project (or select an existing one)
#   3. APIs & Services → OAuth consent screen → configure (External, Testing is fine)
#   4. APIs & Services → Credentials → Create Credentials → OAuth client ID
#   5. Application type: Web application
#   6. Authorized redirect URIs — add both:
#        http://localhost:3000/api/auth/oauth/callback/google   (development)
#        https://yourdomain.com/api/auth/oauth/callback/google  (production)
#   7. Copy Client ID and Client Secret
#
# Docs: https://developers.google.com/identity/protocols/oauth2/web-server
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# -----------------------------------------------------------------------------
# GitHub OAuth
# -----------------------------------------------------------------------------
# Setup:
#   1. Go to https://github.com/settings/developers
#   2. Click "New OAuth App"
#   3. Fill in:
#        Application name:      Your App Name
#        Homepage URL:          https://yourdomain.com
#        Authorization callback URL:
#          Development: http://localhost:3000/api/auth/oauth/callback/github
#          Production:  https://yourdomain.com/api/auth/oauth/callback/github
#   4. Click "Register application"
#   5. On the app page click "Generate a new client secret"
#   6. Copy Client ID and Client Secret
#
# Note: Create separate OAuth Apps for development and production to keep
#       callback URLs isolated.
#
# Docs: https://docs.github.com/en/apps/oauth-apps/building-oauth-apps/creating-an-oauth-app
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
