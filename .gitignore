# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies
/node_modules/
.yarn/
.pnp
.pnp.js
.yarn/install-state.gz

# Build outputs
/build/
/out/
.next/
.turbo/
.swc/

# Testing & coverage
/coverage/

# Environment variables — never commit secrets
.env
.env.development
.env.test
.env.staging
.env.uat
.env.production
.env*.local
*.env.sentry-build-plugin

# Logs
logs/
*.log
*.logs
logs*.json
docker.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE & editor settings
.idea/
.vscode/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# TypeScript & Next.js artifacts
*.tsbuildinfo
next-env.d.ts

# Security — never commit keys or certificates
*.pem
*.key
*.crt

# Databases
*.sqlite
*.sqlite3
/prisma/dev.db

# Tool caches
.cache/
.eslintcache

# Generated docs
/documentation/

# Vercel
.vercel/

# Local uploads — dev-only user content
/public/assets/

# Storybook
storybook-static/

# Lock files — keep only ONE for your package manager
# Uncomment the ones you do NOT use:
# package-lock.json
# yarn.lock
pnpm-lock.yaml
/app/generated/prisma

/generated/prisma

/lib/generated/prisma
