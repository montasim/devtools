# pnpm configuration

# Prefer offline mode for faster installs
prefer-offline=true

# Auto-install peer dependencies
auto-install-peers=true

# Strict peer dependencies (set to false for compatibility)
strict-peer-dependencies=false

# Use shamefully-hoist for compatibility with tools that expect
# dependencies in node_modules (optional)
# shamefully-hoist=false

# Enable strict dependency resolution
strict-peer-dependencies=false
