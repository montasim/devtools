// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Shareable app state models
model SharedLink {
  id           String    @id @default(cuid())
  userId       String?   // Optional - null for anonymous shares
  pageName     String // 'text', 'json', 'base64'
  tabName      String // 'diff', 'format', etc.
  title        String // User-provided title
  comment      String? // Optional user-provided comment
  expiresAt    DateTime? // Null = never expires
  passwordHash String? // Null = public access
  viewCount    Int       @default(0)
  updatedAt    DateTime  @updatedAt
  createdAt    DateTime  @default(now())

  user    User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content SharedContent?

  @@index([pageName])
  @@index([createdAt])
  @@index([expiresAt])
  @@index([userId])
}

model SharedContent {
  id     String     @id @default(cuid())
  linkId String     @unique
  state  Json // Page-specific state as JSON
  link   SharedLink @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@index([linkId])
}

// Saved items model for user bookmarks/saved content
model SavedItem {
  id        String   @id @default(cuid())
  userId    String?  // Optional - null for anonymous saves
  pageName  String   // 'text', 'json', 'base64'
  tabName   String   // 'diff', 'format', etc.
  name      String   // User-provided name
  content   Json     // Page-specific content as JSON
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([pageName])
  @@index([createdAt])
  @@index([userId])
}

// ─── Authentication ──────────────────────────────────────────────────────

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  passwordHash   String
  name           String
  emailVerified  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  otps           UserOtp[]
  shares         SharedLink[]
  savedItems     SavedItem[]
}

model UserOtp {
  id        String   @id @default(uuid())
  email     String
  codeHash  String   // HMAC-SHA256(otp, OTP_HMAC_SECRET)
  intent    String   // REGISTER | PASSWORD_RESET
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime  @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: Cascade)

  @@index([email, intent, used, expiresAt])
}
